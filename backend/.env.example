# ── MuGate Backend Environment ──
# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`.

# Server
PORT=5000

# Security secrets (use long, random values in production)
JWT_SECRET=change-me-to-a-long-random-string
ENCRYPTION_SECRET=change-me-to-a-long-random-string

# SQL Server database
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SERVER=127.0.0.1
DB_NAME=MuGate

# University website used to build the RAG knowledge base
UNIVERSITY_WEBSITE_URL=https://mu.edu.lb

# AI providers — add the keys for the providers you use (fallback cascade)
DEEPSEEK_API_KEY=your_deepseek_api_key
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Which provider to try first (deepseek | gemini | openrouter)
AI_PRIMARY_PROVIDER=deepseek

# Optional: override the model used per provider
DEEPSEEK_MODEL=deepseek-chat
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free
