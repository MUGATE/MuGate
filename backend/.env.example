# Server
PORT=5000
NODE_ENV=production

# Auth secrets — REQUIRED: use strong random values (min 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars-long
ENCRYPTION_SECRET=replace-with-another-random-secret-at-least-32-chars

# Immortal super-admin university ID (leave empty to rely only on Admins table)
SUPER_ADMIN_UNIVERSITY_ID=101230004

# Comma-separated browser origins allowed to call the API (required in production)
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Postgres TLS: set true only when the CA is trusted/pinned
DB_SSL_REJECT_UNAUTHORIZED=false

# Supabase Postgres (required in production)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Optional alias for DATABASE_URL
# SUPABASE_DB_URL=

# Local SQL Server only (ignored when DATABASE_URL is set)
# DB_USER=
# DB_PASSWORD=
# DB_SERVER=127.0.0.1
# DB_NAME=MuGate

# AI providers (at least one for real chatbot / resume AI)
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
AI_PRIMARY_PROVIDER=deepseek
# DEEPSEEK_MODEL=deepseek-chat
# GEMINI_MODEL=gemini-2.5-flash
# OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

# Safer first deploy — disable until API is healthy
AUTO_INITIAL_CRAWL=false

# Optional
# CURRENT_SEMESTER_ID=
# FORCE_COURSE_SYNC=false
# Cron course sync credentials (preferred over scraper-credentials.json)
# SCRAPER_UNIVERSITY_ID=
# SCRAPER_PASSWORD=
# SCRAPER_SEMESTER_ID=
# UNIVERSITY_WEBSITE_URL=https://mu.edu.lb
# CHROMA_URL=
# CHROMA_PATH=./data/chroma
